# MCP Router System - Environment Variables

# Configuration directory location
# Default: ~/.onemcp
# ONEMCP_CONFIG_DIR=/path/to/config

# Log level
# Options: DEBUG, INFO, WARN, ERROR
# Default: INFO
# LOG_LEVEL=INFO

# Server mode port (only used in server mode)
# Default: 3000
# PORT=3000

# Node environment
# Options: development, production, test
# Default: production
# NODE_ENV=production
